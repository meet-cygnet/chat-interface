# Full endpoint URL. Supported shapes:
#   Azure Chat Completions:  https://<res>.openai.azure.com/openai/deployments/<dep>/chat/completions?api-version=2025-01-01-preview
#   Azure AI Foundry Responses: https://<res>.cognitiveservices.azure.com/openai/responses?api-version=2025-04-01-preview
#   OpenAI:                  https://api.openai.com/v1/chat/completions
TARGET_URI=https://openai-test-demo3.openai.azure.com/openai/deployments/gpt-4o/chat/completions?api-version=2025-01-01-preview
API_KEY=your-key-here

# Required only for the Azure Responses API (deployment name in Foundry, e.g. gpt-4o)
AZURE_DEPLOYMENT=

# ── Server ───────────────────────────────────────────────────────────────
# Port for the Streamlit UI
PORT=8501
# FastAPI backend port
BACKEND_PORT=8000
BACKEND_HOST=127.0.0.1
# Uvicorn worker count (Keep at 1 for Socket.IO WebSockets to function properly locally)
WORKERS=1

# ── Networking ───────────────────────────────────────────────────────────
# Set to false to bypass SSL verification (insecure)
VERIFY_SSL=true
# Connection pool size (max concurrent outbound connections)
POOL_SIZE=100
# Timeouts in seconds
CONNECT_TIMEOUT=5.0
READ_TIMEOUT=60.0
WRITE_TIMEOUT=10.0

# ── Retry ────────────────────────────────────────────────────────────────
MAX_RETRIES=3
RETRY_BACKOFF_BASE=0.5

# ── Rate Limiting ────────────────────────────────────────────────────────
# Global requests per second
RATE_LIMIT_RPS=100
# Max burst above sustained rate
RATE_LIMIT_BURST=150

# ── Logging ──────────────────────────────────────────────────────────────
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# json (production) or text (development)
LOG_FORMAT=text
